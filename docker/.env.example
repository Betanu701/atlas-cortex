# ── Atlas Cortex Environment Configuration ───────────────────────
# Copy to .env and customize. All values shown are defaults.

# ── General ──────────────────────────────────────────────────────
TZ=America/New_York
PUID=99
PGID=100

# ── Atlas Cortex Server ──────────────────────────────────────────
CORTEX_PORT=5100
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=atlas-admin

# ── LLM Backend (HuggingFace Transformers on local GPU) ──────────
LLM_PROVIDER=transformers
CAG_MODEL=Qwen/Qwen3-4B
EMBED_MODEL=all-MiniLM-L6-v2
MODEL_FAST=qwen3.5:9b
MODEL_THINKING=qwen3.5:27b
MODEL_EMBEDDING=nomic-embed-text
# Legacy Ollama settings (uncomment if using LLM_PROVIDER=ollama)
# LLM_URL=http://localhost:11434
# LLM_API_KEY=           # Only needed for OpenAI/Anthropic providers

# ── Data Storage ─────────────────────────────────────────────────
# Base path for all Atlas data (DB, models, LoRAs, TTS cache, etc.)
# Set to a fast pool/SSD with enough space for models (~50GB+)
ATLAS_DATA_BASE=/mnt/fastpool/atlas
# Individual paths (derived from ATLAS_DATA_BASE by default):
# CORTEX_DATA_DIR=${ATLAS_DATA_BASE}/data        # DB, config, cache
# OLLAMA_MODELS=${ATLAS_DATA_BASE}/models/ollama  # Ollama model storage
# LORA_DIR=${ATLAS_DATA_BASE}/models/loras        # LoRA adapters
# TTS_CACHE_DIR=${ATLAS_DATA_BASE}/cache/tts      # Pre-generated TTS audio

# Ollama LLM container image:
#   CPU:       ollama/ollama:latest
#   AMD ROCm:  ollama/ollama:rocm
OLLAMA_LLM_IMAGE=ollama/ollama:latest

# ── TTS (Orpheus primary via llama.cpp CUDA + SNAC, port 5005) ────
TTS_PROVIDER=orpheus
ORPHEUS_FASTAPI_URL=http://localhost:5005
ORPHEUS_MODEL_NAME=Orpheus-3b-FT-Q4_K_M.gguf
# Also available: Orpheus-3b-FT-Q8_0.gguf (higher quality, ~45% slower)

# llama.cpp inference settings
LLAMA_GPU_LAYERS=99
LLAMA_CTX_SIZE=4096

# Single container: llama.cpp CUDA for token generation, SNAC for audio decode.
# GGUF model auto-downloaded on first run (~2.2GB).

# ── TTS Fallback (Piper CPU, port 10200) ─────────────────────────
PIPER_HOST=localhost
PIPER_PORT=10200
PIPER_VOICE=en_US-lessac-medium
PIPER_LENGTH=1.0
PIPER_NOISE=0.667
PIPER_NOISEW=0.333
PIPER_SPEAKER=0
PIPER_PROCS=1

# ── STT (whisper.cpp Vulkan, port 10300) ──────────────────────────
# Backend: "whisper_cpp" (HTTP API) or "wyoming" (Wyoming protocol)
STT_BACKEND=whisper_cpp
STT_HOST=localhost
STT_PORT=10300
WHISPER_MODEL=large-v3-turbo-q5_0
WHISPER_BEAM=5
WHISPER_LANG=en
# WHISPER_VK_DEVICE=1  # Set in GPU override (0=first GPU, 1=second)

# Keep models loaded forever in multi-GPU mode (no unload latency)
OLLAMA_KEEP_ALIVE=0

# ── GPU Configuration ───────────────────────────────────────────
# GPU assignment per plan:
#   GPU 0 (largest VRAM)  → LLM + STT   (atlas-ollama,  atlas-whisper)
#   GPU 1 (NVIDIA CUDA)   → Voice/TTS   (atlas-orpheus, port 5005)
#
# For GPU support, use the appropriate override file:
#   AMD+NVIDIA: docker compose -f docker-compose.yml -f docker-compose.gpu-amd.yml up -d
#   NVIDIA:     docker compose -f docker-compose.yml -f docker-compose.gpu-nvidia.yml up -d
#   Intel:      docker compose -f docker-compose.yml -f docker-compose.gpu-intel.yml up -d
