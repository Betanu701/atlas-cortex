        "laughing": {
            "replace_mouth": true,
            "replace_eyes": true,
            "mouth": {
                "type": "path",
                "d": "M -30,-5 Q 0,35 30,-5 Z",
                "stroke": "#333",
                "stroke_width": 3,
                "fill": "#fff"
            },
            "description": "Wide open laugh"
        },
        "silly": {
            "replace_mouth": true,
            "replace_eyes": true,
            "mouth": {
                "type": "path",
