{
    "version": 1,
    "description": "Shared expression mouth library for cartoon-style Atlas avatars",
    "expressions": {
        "happy": {
            "replace_mouth": true,
            "replace_eyes": false,
            "mouth": {
                "type": "path",
                "d": "M -30,0 Q 0,25 30,0",
                "stroke": "#333",
                "stroke_width": 4,
                "fill": "none",
                "stroke_linecap": "round"
            },
            "description": "Wide smile arc curving upward"
        },
        "sad": {
            "replace_mouth": true,
            "replace_eyes": false,
            "mouth": {
                "type": "path",
                "d": "M -25,8 Q 0,-12 25,8",
                "stroke": "#333",
                "stroke_width": 4,
                "fill": "none",
                "stroke_linecap": "round"
            },
            "description": "Downward frown"
        },
        "angry": {
            "replace_mouth": true,
            "replace_eyes": false,
            "mouth": {
                "type": "path",
                "d": "M -20,5 Q 0,-8 20,5",
                "stroke": "#333",
                "stroke_width": 4.5,
                "fill": "none",
                "stroke_linecap": "round"
            },
            "description": "Tight narrow frown"
        },
        "surprised": {
            "replace_mouth": true,
            "replace_eyes": false,
            "mouth": {
                "type": "ellipse",
                "rx": 12,
                "ry": 16,
                "fill": "#333",
                "opacity": 0.85
            },
            "description": "Open O shape"
        },
        "thinking": {
            "replace_mouth": true,
