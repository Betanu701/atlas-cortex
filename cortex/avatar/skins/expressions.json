        "listening": {
            "replace_mouth": false,
            "replace_eyes": false,
            "description": "Uses default IDLE mouth"
        },
        "neutral": {
            "replace_mouth": false,
            "replace_eyes": false,
            "description": "Uses default IDLE mouth"
