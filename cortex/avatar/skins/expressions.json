        "crying": {
            "replace_mouth": true,
            "replace_eyes": false,
            "mouth": {
                "type": "path",
                "d": "M -22,12 Q 0,-18 22,12 Q 0,22 -22,12 Z",
                "stroke": "#333",
                "stroke_width": 3,
